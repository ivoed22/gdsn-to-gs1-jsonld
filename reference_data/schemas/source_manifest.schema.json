{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/gdsn-to-gs1-jsonld/source_manifest.schema.json",
  "title": "Public source data manifest",
  "type": "object",
  "required": [
    "schema_version",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_for": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "source_url",
          "retrieved_at",
          "version",
          "local_path",
          "sha256",
          "public_accessible",
          "authoritative_or_derived",
          "used_by",
          "license_or_rights_note",
          "usage_note"
        ],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "version": {
            "type": "string"
          },
          "local_path": {
            "type": "string"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{64}$"
          },
          "public_accessible": {
            "type": "boolean"
          },
          "authoritative_or_derived": {
            "type": "string"
          },
          "used_by": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "license_or_rights_note": {
            "type": "string"
          },
          "usage_note": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
